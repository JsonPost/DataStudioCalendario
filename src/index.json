{
  "data": [
    {
      "id": "concepts",
      "label": "Datos del Calendario",
      "elements": [
        {
          "id": "fecha",
          "label": "Fecha",
          "type": "DIMENSION",
          "options": {
            "min": 1,
            "max": 1,
            "supportedTypes": ["DATE", "YEAR_MONTH", "DATE_HOUR"]
          }
        },
        {
          "id": "tarea",
          "label": "Nombre de Task",
          "type": "DIMENSION",
          "options": {
            "min": 1,
            "max": 1,
            "supportedTypes": ["TEXT"]
          }
        },
        {
          "id": "estado",
          "label": "Estado / Categoría",
          "type": "DIMENSION",
          "options": {
            "min": 0,
            "max": 1,
            "supportedTypes": ["TEXT"]
          }
        },
        {
          "id": "metrica",
          "label": "Métrica (ej: horas, puntos)",
          "type": "METRIC",
          "options": {
            "min": 0,
            "max": 1
          }
        }
      ]
    }
  ],
  "style": [
    {
      "id": "opciones",
      "label": "Opciones del Calendario",
      "elements": [
        {
          "id": "vistaDefault",
          "label": "Vista por defecto",
          "type": "SELECT_SINGLE",
          "defaultValue": "month",
          "options": [
            { "label": "Mensual", "value": "month" },
            { "label": "Semanal", "value": "week" }
          ]
        },
        {
          "id": "primeraFila",
          "label": "Primer día de la semana",
          "type": "SELECT_SINGLE",
          "defaultValue": "0",
          "options": [
            { "label": "Domingo", "value": "0" },
            { "label": "Lunes", "value": "1" }
          ]
        },
        {
          "id": "mostrarMetrica",
          "label": "Mostrar métrica en chips",
          "type": "CHECKBOX",
          "defaultValue": "true"
        }
      ]
    }
  ]
}
